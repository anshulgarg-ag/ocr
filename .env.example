# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_ROOT=s3://ocr-pipeline

# MinIO runs locally in Docker. JarvisLabs reaches it via SSH reverse tunnel
# (deploy_jarvis.sh sets this up automatically — no router config needed).
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── PostgreSQL (state tracking + dead letter queue) ───────────────────────────
POSTGRES_URL=postgresql+asyncpg://ocr:ocr@localhost:5432/ocr_pipeline
POSTGRES_SYNC_URL=postgresql://ocr:ocr@localhost:5432/ocr_pipeline

# ── Qdrant (vector store) ─────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=documents

# ── Neo4j (full knowledge graph) ──────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword

# ── GPU Provider ─────────────────────────────────────────────────────────────
GPU_PROVIDER_TYPE=self_hosted   # self_hosted | jarvis
# Only needed for self_hosted (if services are not on localhost):
GPU_OCR_URL=http://localhost:8001
GPU_EMBED_URL=http://localhost:8002
GPU_GRAPH_URL=http://localhost:8003

# ── JarvisLabs GPU instance ───────────────────────────────────────────────────
JARVIS_HOST=217.18.55.79
JARVIS_USER=ubuntu
JARVIS_SSH_KEY_PATH=           # leave blank if using ssh-agent / default key
JARVIS_MAX_RUNTIME_HOURS=12

# Services on JarvisLabs (set after deploy_jarvis.sh runs)
JARVIS_OCR_URL=http://217.18.55.79:8001
JARVIS_EMBED_URL=http://217.18.55.79:8002
JARVIS_GRAPH_URL=http://217.18.55.79:8003

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOKI_URL=http://localhost:3100
PROMETHEUS_PORT=9090
LOG_LEVEL=INFO
LOG_FORMAT=json  # json | pretty

# ── Alerts ────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...  # optional

# ── Model paths (set to local dir after uploading via rsync; leave blank to pull from HF) ─────
# After running: rsync -avz models/ ubuntu@<IP>:~/models/
# set these so services never hit HuggingFace on startup:
OCR_MODEL=/home/ubuntu/models/chandra-ocr-2
EMBED_MODEL=/home/ubuntu/models/bge-m3
GRAPH_MODEL=/home/ubuntu/models/Qwen2.5-7B-Instruct

# ── Pipeline tuning ───────────────────────────────────────────────────────────
OCR_WORKERS=1
EMBED_BATCH_SIZE=64
MAX_RETRIES=3
ENTITY_CONFIDENCE_MIN=0.6
CHUNK_MAX_TOKENS=1024
CHUNK_OVERLAP_TOKENS=128
